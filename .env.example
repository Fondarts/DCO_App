# ============================================
# DCO App — Environment Variables
# ============================================

# --- Database ---
DATABASE_URL="file:./dev.db"
# For production: DATABASE_URL="postgresql://user:pass@host:5432/dco"

# --- Redis (required for queue-based rendering) ---
REDIS_URL="redis://localhost:6379"

# --- Auth ---
NEXTAUTH_SECRET="change-this-to-a-random-string"
NEXTAUTH_URL="http://localhost:3000"

# --- Render Mode ---
# "local"  = render in web process (no Redis needed)
# "queue"  = always use BullMQ queue (requires Redis + worker)
# "auto"   = try queue, fall back to local (default)
RENDER_MODE="auto"

# --- Storage ---
# "local" = filesystem (default)
# "s3"    = S3-compatible (MinIO, AWS, etc.)
STORAGE_PROVIDER="local"
STORAGE_PATH="./storage"

# --- S3 Storage (when STORAGE_PROVIDER=s3) ---
# S3_ENDPOINT="http://localhost:9000"   # MinIO endpoint
# S3_BUCKET="dco-storage"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY="minioadmin"
# S3_SECRET_KEY="minioadmin"

# --- Worker API ---
WORKER_API_KEY="worker-secret"

# ============================================
# Worker-specific env vars (apps/worker)
# ============================================

# API_URL="http://localhost:3000"        # Web server URL
# WORKER_ID="worker-1"                   # Unique worker identifier
# WORKER_WORKDIR="./storage/tmp/nexrender"

# --- After Effects & FFmpeg paths (auto-detected if not set) ---
# AERENDER_PATH="C:\Program Files\Adobe\Adobe After Effects 2025\Support Files\aerender.exe"
# FFMPEG_PATH="C:\path\to\ffmpeg.exe"

# --- Storage root for worker (must match web server's storage) ---
# STORAGE_ROOT="./storage"
